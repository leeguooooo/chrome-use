{
  "manifest_version": 3,
  "name": "chrome-use",
  "version": "0.4.11",
  "description": "Let chrome-use drive your logged-in Chrome \u2014 install once, no token, no per-use confirmation.",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "debugger",
    "tabs",
    "tabGroups",
    "nativeMessaging",
    "storage",
    "alarms",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "chrome-use",
    "default_popup": "popup.html"
  }
}
